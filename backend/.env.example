# Copy to .env and fill in. The only required secret is the Gemini API key.
GEMINI_API_KEY= your-api-key 

# Optional overrides (sensible defaults in app/config.py):
# Both stages default to Flash-Lite to survive the free tier (gemini-2.5-flash
# is capped at ~20 requests/day). With billing/quota, upgrade verdicts to Flash:
# NW_MODEL_REASONING=gemini-2.5-flash
# NW_MODEL_EXTRACT=gemini-2.5-flash-lite
# NW_EMBED_MODEL=gemini-embedding-001
# NW_STATE_DIR=/data            # persistent volume mount in production
# NW_RETRIEVAL_TOP_K=8
# Per-minute rate caps (raise these on a paid tier for speed):
# NW_GEN_RPM=13                 # gemini-2.5-flash
# NW_GEN_RPM_LITE=28            # gemini-2.5-flash-lite
